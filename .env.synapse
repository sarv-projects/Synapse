# SYNAPSE v3.0 Environment Configuration

# Neo4j Aura Free
NEO4J_URI=bolt://your-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-password
NEO4J_DATABASE=neo4j

# PostgreSQL Checkpoint (Neon.dev free tier)
POSTGRES_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/synapse

# Qdrant Cloud (free tier)
QDRANT_URL=https://xxx.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-key

# LLM Providers
GROQ_API_KEY=gsk_xxx
GROQ_MODEL=llama-4-scout-17b
GEMINI_API_KEY=AIzaSyxxx

# GitHub (optional - raises rate limit)
GITHUB_TOKEN=ghp_xxx

# API Security
SYNAPSE_ADMIN_KEY=generate-random-string-here
API_VERSION=v1
CORS_ORIGINS=http://localhost:5173,https://synapse.yourdomain.com

# System
LOG_LEVEL=INFO
DEFAULT_DOMAIN=ai
QUERY_CACHE_TTL_SECONDS=3600
MAX_QUERY_RESULTS=50
MAX_TRAVERSAL_DEPTH=3
