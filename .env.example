# SYNAPSE v4.0 Environment Configuration
# === REQUIRED ===
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-password
NEO4J_DATABASE=neo4j

# Groq (supports comma-separated keys for rotation)
GROQ_API_KEYS=key1,key2,key3
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_MODELS_ENABLED=meta-llama/llama-4-scout-17b-16e-instruct,llama-3.3-70b-versatile,openai/gpt-oss-20b,openai/gpt-oss-120b,llama-3.1-8b-instant,qwen-qwq-32b

# Google Gemini (required for LaTeX Create Agent)
# GEMINI_API_KEY=   (removed — v4.0 uses Groq-only pipeline)

# Source authentication
GITHUB_TOKEN=

# PostgreSQL / pgvector (Neon.dev free tier — vector store + halfvec(384))
POSTGRES_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/synapse

# Google Cloud (Firestore checkpointing — free tier 50k reads/20k writes/day)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GCP_PROJECT=your-gcp-project-id

# === v4.0 ADDITIONS ===

# AWS (DynamoDB + S3 + SQS)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
DYNAMODB_TABLE=synapse_jobs
S3_BUCKET=synapse-reports
SQS_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/123456789/synapse-reasoning-queue

# Tavily search (1,000 free credits/month)
TAVILY_API_KEY=

# ZenRows anti-bot fallback scraper
ZENROWS_API_KEY=

# MCP servers (paths to local executables)
MCP_MEMORY_PATH=
MCP_SEQUENTIAL_THINKING_PATH=
MCP_FILESYSTEM_PATH=

# HuggingFace token (for gated models)
HF_TOKEN=

# === Application controls ===
SYNAPSE_ADMIN_KEY=change-me
API_VERSION=v1
CORS_ORIGINS=http://localhost:5173
LOG_LEVEL=INFO
DEFAULT_DOMAIN=ai

# Query & Cache
QUERY_CACHE_TTL_SECONDS=3600
MAX_QUERY_RESULTS=50
MAX_TRAVERSAL_DEPTH=3

# v4.0 thresholds
BUDGET_RPD_ALERT_THRESHOLD=0.80
CRAWL4AI_TIMEOUT=30
RETRIEVAL_CONFIDENCE_THRESHOLD=0.65
CRITIC_MAX_RETRIES=2
LATEX_COMPILE_TIMEOUT=120
